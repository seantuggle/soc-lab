# SOC Lab .gitignore

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Database (don't commit data, only schema)
db/*.db
db/*.db-wal
db/*.db-shm

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Logs
*.log
logs/

# Docker
.docker/

# Environment files (may contain secrets)
.env
.env.local

# pytest cache
.pytest_cache/
.coverage
htmlcov/
